# Copy to .env and source it (or pass via your process manager).
# Generate a strong key:  python3 -c "import os;print(os.urandom(32).hex())"
STEGO_SECRET_KEY=change-me-to-a-random-64-hex-string
STEGO_HOST=127.0.0.1        # bind localhost only; put a reverse proxy in front for prod
STEGO_PORT=5000
STEGO_DEBUG=0               # NEVER set to 1 on a reachable host
STEGO_UPLOAD_DIR=uploads
STEGO_MAX_MB=200            # max upload size
STEGO_DECRYPT_TTL=300       # seconds before decrypted outputs auto-delete
STEGO_FILE_TTL=3600         # seconds before other temp files auto-delete
STEGO_DECOY=0              # 1 = return a decoy file on decryption failure (opt-in)
